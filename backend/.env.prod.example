PROJECT_NAME=crm-desarrollo-main-webready
APP_ENV=prod

# Django runtime
DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=replace-with-strong-secret-min-32-chars
DEBUG=0

# Service ports (container side defaults)
BACKEND_PORT=8000
NGINX_PORT=8073
POSTGRES_PORT=5432
REDIS_PORT=6379

# Database
POSTGRES_DB=tasktracking
POSTGRES_USER=tasktracking
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_HOST=postgres

# Redis
REDIS_HOST=redis

# Public hosts and browser security boundaries
# Local prod (no TLS): usa localhost/127.0.0.1 o tu IP real (agregala aqui). No usar 0.0.0.0.
ALLOWED_HOSTS=app.example.com,api.example.com,localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=https://app.example.com
CSRF_TRUSTED_ORIGINS=https://app.example.com

# TLS and proxy hardening
# Local prod sin TLS: 0. En entorno real con TLS terminado en proxy/LB: 1.
SECURE_SSL_REDIRECT=0
USE_X_FORWARDED_PROTO=1
ENABLE_HSTS=1
SECURE_HSTS_SECONDS=31536000

# JWT
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=7

# Container bootstrap flags
RUN_MIGRATIONS=1
COLLECTSTATIC=1
HEALTHCHECK_REDIS_REQUIRED=1
# Solo para entornos demo/local. En prod real debe ser 0.
SEED_DEMO_USERS=0
