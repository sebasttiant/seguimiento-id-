PROJECT_NAME=crm-desarrollo-main-webready
APP_ENV=dev

# Django runtime
DJANGO_SETTINGS_MODULE=config.settings.local
SECRET_KEY=dev-only-change-me
DEBUG=1

# Service ports (container side defaults)
BACKEND_PORT=8000
NGINX_PORT=8080
POSTGRES_PORT=5432
REDIS_PORT=6379

# Database
POSTGRES_DB=tasktracking
POSTGRES_USER=tasktracking
POSTGRES_PASSWORD=tasktracking
POSTGRES_HOST=postgres

# Redis
REDIS_HOST=redis

# Browser/API origins
ALLOWED_HOSTS=localhost,127.0.0.1,backend,nginx
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:8080,http://localhost:5173,http://127.0.0.1:5173

# JWT
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=7

# Container bootstrap flags
RUN_MIGRATIONS=1
COLLECTSTATIC=1
HEALTHCHECK_REDIS_REQUIRED=1
