PROJECT_NAME=crm-desarrollo-main-webready
APP_ENV=prod
COMPOSE_PROJECT_NAME=crmwebready-prod

# Public published ports
FRONTEND_PORT=5173
BACKEND_PORT=8000
NGINX_PORT=8073
POSTGRES_PORT=5432
REDIS_PORT=6379

# Shared service connectivity (replace placeholder secrets)
POSTGRES_DB=tasktracking
POSTGRES_USER=tasktracking
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_HOST=postgres
REDIS_HOST=redis

# Frontend runtime configuration (usually proxied by nginx)
VITE_API_BASE_URL=/api
VITE_PROJECT_DATA_SOURCE=api
VITE_AUTH_MODE=api
VITE_HTTP_TIMEOUT_MS=10000

# Backend env files consumed by Compose overlays
BACKEND_ENV_FILE_DEV=./backend/.env.dev
BACKEND_ENV_FILE_PROD=./backend/.env.prod
