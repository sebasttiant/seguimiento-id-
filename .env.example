PROJECT_NAME=crm-desarrollo-main-webready
APP_ENV=dev
COMPOSE_PROJECT_NAME=crmwebready-dev

# Public published ports
FRONTEND_PORT=5173
BACKEND_PORT=8000
NGINX_PORT=8080
POSTGRES_PORT=5432
REDIS_PORT=6379

# Shared service connectivity
POSTGRES_DB=tasktracking
POSTGRES_USER=tasktracking
POSTGRES_PASSWORD=tasktracking
POSTGRES_HOST=postgres
REDIS_HOST=redis

# Frontend runtime configuration
VITE_API_BASE_URL=http://localhost:8080/api
VITE_PROJECT_DATA_SOURCE=api
VITE_AUTH_MODE=api
VITE_HTTP_TIMEOUT_MS=10000

# Backend env files consumed by Compose overlays
BACKEND_ENV_FILE_DEV=./backend/.env.dev
BACKEND_ENV_FILE_PROD=./backend/.env.prod

# UID/GID mapping to avoid permissions issues in dev
HOST_UID=1000
HOST_GID=1000
